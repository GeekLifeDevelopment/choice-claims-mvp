generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Claim {
  id                   String   @id @default(cuid())
  claimNumber          String   @unique
  dedupeKey            String?  @unique
  status               String
  source               String?
  vin                  String?
  claimantName         String?
  claimantEmail        String?
  claimantPhone        String?
  rawSubmissionPayload Json
  vinDataResult        Json?
  vinDataRawPayload    Json?
  vinDataProvider      String?
  vinDataFetchedAt     DateTime?
  vinDataProviderResultCode Int?
  vinDataProviderResultMessage String?
  vinLookupRetryRequestedAt DateTime?
  vinLookupAttemptCount Int      @default(0)
  vinLookupLastError    String?
  vinLookupLastFailedAt DateTime?
  vinLookupLastJobId    String?
  vinLookupLastJobName  String?
  vinLookupLastQueueName String?
  reviewRuleFlags       Json?
  reviewRuleEvaluatedAt DateTime?
  reviewRuleVersion     String?
  reviewRuleLastError   String?
  reviewSummaryStatus      String?
  reviewSummaryEnqueuedAt  DateTime?
  reviewSummaryGeneratedAt DateTime?
  reviewSummaryText        String?
  reviewSummaryLastError   String?
  reviewSummaryJobId       String?
  reviewSummaryVersion     String?
  reviewDecision           String?
  reviewDecisionSetAt      DateTime?
  reviewDecisionNotes      String?
  reviewDecisionBy         String?
  reviewDecisionVersion    String?
  submittedAt          DateTime
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  attachments     ClaimAttachment[]
  claimDocuments  ClaimDocument[]
  auditLogs       AuditLog[]

  @@index([status])
  @@index([submittedAt])
}

model ClaimDocument {
  id               String   @id @default(cuid())
  claimId          String
  fileName         String
  mimeType         String
  storageKey       String
  fileSize         Int
  uploadedBy       String?
  processingStatus String   @default("uploaded")
  documentType     String?
  matchStatus      String?
  matchNotes       String?
  parsedAnchors    Json?
  extractionStatus String   @default("pending")
  extractedAt      DateTime?
  extractedData    Json?
  extractionWarnings Json?
  uploadedAt       DateTime @default(now())

  claim Claim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId])
  @@index([processingStatus])
  @@index([extractionStatus])
}

model ClaimAttachment {
  id         String   @id @default(cuid())
  claimId    String
  filename   String
  mimeType   String?
  sourceUrl  String?
  externalId String?
  storageKey String?
  fileSize   Int?
  uploadedAt DateTime @default(now())

  claim Claim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId])
}

model AuditLog {
  id        String   @id @default(cuid())
  claimId   String?
  action    String
  fieldName String?
  oldValue  Json?
  newValue  Json?
  metadata  Json?
  createdAt DateTime @default(now())

  claim Claim? @relation(fields: [claimId], references: [id], onDelete: SetNull)

  @@index([claimId])
  @@index([action])
  @@index([createdAt])
}
