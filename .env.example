# Environment variables for Choice Claims MVP (example)

NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL=
DIRECT_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
COGNITO_WEBHOOK_SECRET=
COGNITO_WEBHOOK_DEBUG=false
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
OPENAI_API_KEY=
RESEND_API_KEY=
REDIS_URL=
QUEUE_PREFIX=choice-claims

# Provider configuration (Sprint 3 Ticket 1)
# These are for future live integrations. Stub providers still work when unset.
CARFAX_API_KEY=
CARFAX_API_URL=
AUTOCHECK_API_KEY=
AUTOCHECK_API_URL=

# Optional provider request timeout in milliseconds (defaults to 10000).
VIN_PROVIDER_TIMEOUT_MS=10000

# Notes:
# - Copy this file to .env.local when developing and fill in values.
# - Do NOT commit real secrets; use Netlify environment variables for production.
# - REDIS_URL is required only when queue infrastructure is invoked.
# - QUEUE_PREFIX is optional and defaults to "choice-claims".
# - CARFAX/AUTOCHECK credentials are not required while using stub providers.
