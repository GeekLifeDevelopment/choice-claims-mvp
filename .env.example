# Environment variables for Choice Claims MVP (example)

NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL=
DIRECT_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
COGNITO_WEBHOOK_SECRET=
COGNITO_WEBHOOK_DEBUG=false
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
OPENAI_API_KEY=
RESEND_API_KEY=
REDIS_URL=
QUEUE_PREFIX=choice-claims

# Provider credential config (Sprint 3 foundation)
# Stub providers continue to work with these unset.
CARFAX_API_KEY=
CARFAX_API_URL=
AUTOCHECK_API_KEY=
AUTOCHECK_API_URL=

# OAuth provider config for future Experian/AutoCheck integration.
# Sandbox example base URL: https://sandbox-us-api.experian.com
EXPERIAN_BASE_URL=
EXPERIAN_USERNAME=
EXPERIAN_PASSWORD=
EXPERIAN_CLIENT_ID=
EXPERIAN_CLIENT_SECRET=

# Optional provider request timeout in milliseconds.
VIN_PROVIDER_TIMEOUT_MS=10000

# Notes:
# - Copy this file to .env.local when developing and fill in values.
# - Do NOT commit real secrets; use Netlify environment variables for production.
# - REDIS_URL is required only when queue infrastructure is invoked.
# - QUEUE_PREFIX is optional and defaults to "choice-claims".
# - Provider secrets are for future live integrations and should never be logged.
