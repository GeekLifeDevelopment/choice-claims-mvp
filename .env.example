# Environment variables for Choice Claims MVP (example)

NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL=
DIRECT_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
COGNITO_WEBHOOK_SECRET=
COGNITO_WEBHOOK_DEBUG=false
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
OPENAI_API_KEY=
RESEND_API_KEY=
REDIS_URL=
QUEUE_PREREDIS_URL=
QUEUE_PREFIX=choice-claims

# Provider credential config (Sprint 3 foundation)
# Stub providers continue to work with these unset.
CARFAX_API_KEY=
CARFAX_API_URL=
AUTOCHECK_API_KEY=
AUTOCHECK_API_URL=
MARKETCHECK_API_KEY=
MARKETCHECK_API_SECRET=
MARKETCHECK_API_URL=
MARKETCHECK_BASE_URL=
MARKETCHECK_TITLE_HISTORY_GENERATE_PATH=
MARKETCHECK_TITLE_HISTORY_ACCESS_PATH=
MARKETCHECK_SERVICE_HISTORY_PATH=
MARKETCHECK_VALUATION_PATH=
SERVICE_HISTORY_API_URL=
SERVICE_HISTORY_API_KEY=
VALUATION_API_URL=
VALUATION_API_KEY=

# OAuth provider config for future Experian/AutoCheck integration.
# Sandbox example base URL: https://sandbox-us-api.experian.com
# Optional token URL override wins when set.
# If omitted, token URL is derived from EXPERIAN_BASE_URL + /oauth2/v1/token.
# Future production switch should be env-only (swap URLs/credentials; no code changes).
EXPERIAN_BASE_URL=
EXPERIAN_TOKEN_URL=
EXPERIAN_USERNAME=
EXPERIAN_PASSWORD=
EXPERIAN_CLIENT_ID=
EXPERIAN_CLIENT_SECRET=

# Optional overrides for AutoCheck VIN specifications target contract.
# Keep defaults unless Experian confirms different values for your tenant.
EXPERIAN_VINSPECS_TARGET_PATH=/automotive/accuselect/v1/vinspecifications
EXPERIAN_VINSPECS_QUERY_PARAM=vinlist

# Optional provider request timeout in milliseconds.
VIN_PROVIDER_TIMEOUT_MS=10000
PROVIDER_HEALTH_DEBUG=false

# Optional provider priority order (comma-separated).
# Unknown values are ignored; defaults are used when unset/empty.
VIN_PROVIDER_PRIORITY=marketcheck,autocheck,carfax,fallback
TITLE_PROVIDER_PRIORITY=marketcheck,stub
SERVICE_PROVIDER_PRIORITY=service,marketcheck,stub
VALUATION_PROVIDER_PRIORITY=valuation,marketcheck,stub

# Optional sandbox hotfix controls for AutoCheck 429 throttling.
# If unset, sandbox mode auto-detects from EXPERIAN_BASE_URL containing "sandbox".
# When enabled, 429 failures use a slower retry delay to reduce false ProviderFailed outcomes.
AUTOCHECK_SANDBOX_RATE_LIMIT_MODE=
AUTOCHECK_429_RETRY_DELAY_MS=30000

# Optional provider selector used by worker/provider resolver.
# Supported: carfax | autocheck | marketcheck
VIN_DATA_PROVIDER=autocheck

# Notes:
# - Copy this file to .env.local when developing and fill in values.
# - Do NOT commit real secrets; use Netlify environment variables for production.
# - REDIS_URL (or QUEUE_PREREDIS_URL) is required only when queue infrastructure is invoked.
# - QUEUE_PREREDIS_URL takes precedence when both are provided.
# - QUEUE_PREFIX is optional and defaults to "choice-claims".
# - Provider secrets are for future live integrations and should never be logged.
# - AutoCheck live mode requires EXPERIAN_BASE_URL, resolved token URL, credentials, and VIN_DATA_PROVIDER=autocheck.
# - MarketCheck live mode requires MARKETCHECK_API_KEY and VIN_DATA_PROVIDER=marketcheck.
# - MARKETCHECK_API_SECRET and MARKETCHECK_API_URL are optional based on tenant contract.
# - Service history live mode requires either SERVICE_HISTORY_API_URL or MARKETCHECK_SERVICE_HISTORY_PATH.
# - Valuation live mode requires either VALUATION_API_URL or MARKETCHECK_VALUATION_PATH.
# - Priority vars control provider attempt order; when providers are unconfigured/failed, next provider is tried.
